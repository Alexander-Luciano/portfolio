---
layout: base.njk
---
<section class="hero">
    <div class="hero-name-wrap">
        <h1 class="hero-name"><span id="hero-name">{{ site.hero_name }}</span><span class="accent-dot">.</span></h1>
    </div>
    
    <div class="hero-bottom">
        <div class="hero-bio">
            <p id="hero-subtitle">{{ site.hero_subtitle }}</p>
        </div>
        <div class="hero-actions">
            <a href="mailto:alexander7luciano@gmail.com" class="btn btn-dark">Send an Email</a>
            <a href="https://linkedin.com/in/alexanderluciano" target="_blank" class="btn btn-primary">LinkedIn</a>
        </div>
    </div>
</section>

<nav class="main-nav">
    <a href="#projects" class="nav-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg>
        Work
    </a>
    <a href="#about" class="nav-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
        About
    </a>
    <a href="#experience" class="nav-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 12h-4l-3 9L9 3l-3 9H2"></path></svg>
        Experience
    </a>
    <a href="#skills" class="nav-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="16 18 22 12 16 6"></polyline><polyline points="8 6 2 12 8 18"></polyline></svg>
        Skills
    </a>
</nav>

<main>
    <section id="projects" class="section">
        <h2 class="section-title">Selected Work<span class="accent-dot">.</span></h2>
        <div id="projects-container">
            {% for proj in collections.projects %}
            <div class="project-row">
                <div class="project-info">
                    <h3 class="project-title"><a href="{{ proj.url }}" style="color: inherit; text-decoration: none;">{{ proj.data.title }}</a></h3>
                    <div class="project-tech">{{ proj.data.tech }}</div>
                    <p class="project-desc">{{ proj.data.desc }}</p>
                    <a href="{{ proj.url }}" class="btn btn-dark" style="margin-top: 1rem;">View Details</a>
                </div>
                <div class="project-image">
                    {% if proj.data.image %}
                    <a href="{{ proj.url }}"><img src="{{ proj.data.image }}" alt="{{ proj.data.title }}"></a>
                    {% else %}
                    <div style="padding: 4rem; text-align: center; color: #555;">No Image</div>
                    {% endif %}
                </div>
            </div>
            {% endfor %}
        </div>
    </section>

    <section id="about" class="section">
        <h2 class="section-title">About Me<span class="accent-dot">.</span></h2>
        <div id="about-text" style="color: var(--text-secondary); max-width: 800px; font-size: 1.1rem;">
            {{ site.about_text | safe }}
        </div>
    </section>

    <section id="experience" class="section">
        <h2 class="section-title">Experience<span class="accent-dot">.</span></h2>
        <div id="experience-container">
            {% for exp in site.experience %}
            <div class="exp-item">
                <div class="exp-date">{{ exp.date }}</div>
                <div class="exp-content">
                    <h3 class="exp-title">{{ exp.title }}</h3>
                    <h4 class="exp-company">{{ exp.company }}</h4>
                    <ul>
                        {% for item in exp.items %}
                        <li>{{ item }}</li>
                        {% endfor %}
                    </ul>
                </div>
            </div>
            {% endfor %}
        </div>
    </section>

    <section id="skills" class="section">
        <h2 class="section-title">Capabilities<span class="accent-dot">.</span></h2>
        <div id="skills-container" class="skills-grid">
            {% for skill in site.core_competencies %}
            <div class="skill-tag">{{ skill }}</div>
            {% endfor %}
        </div>
    </section>
</main>
