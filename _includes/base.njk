<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title | default(site.hero_name + " | Portfolio") }}</title>
    <meta name="description" content="Portfolio of {{ site.hero_name }}">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&family=Outfit:wght@400;600;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="{{ '/styles.css' | url }}">
    <script src="{{ '/script.js' | url }}" defer></script>
</head>
<body>
    <div class="grid-container">
        <div class="grid-lines">
            <div class="grid-line"></div>
            <div class="grid-line"></div>
            <div class="grid-line"></div>
        </div>

        <header class="top-header">
            <div id="availability-text">{{ site.availability | default('Available') }}</div>
            <div class="profile-wrap">
                {% if site.profile_pic %}
                <a href="{{ '/' | url }}"><img id="profile-pic" src="{{ '/' | url }}{{ site.profile_pic }}" alt="Profile Picture"></a>
                {% endif %}
            </div>
            <div id="location-text">{{ site.location }}</div>
        </header>

        {{ content | safe }}

        <footer>
            <div class="footer-content" style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap;">
                <p>&copy; <span id="current-year">2024</span> {{ site.hero_name }}. All rights reserved.</p>
                <p id="live-datetime" style="font-family: monospace; font-size: 0.9rem; color: var(--text-secondary);"></p>
            </div>
            <script>
                function updateDateTime() {
                    const now = new Date();
                    document.getElementById('current-year').textContent = now.getFullYear();
                    document.getElementById('live-datetime').textContent = now.toLocaleString();
                }
                updateDateTime();
                setInterval(updateDateTime, 1000);
            </script>
        </footer>
    </div>
</body>
</html>
