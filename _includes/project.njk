---
layout: base.njk
---
<nav class="main-nav" style="position: relative; margin-top: 2rem;">
    <a href="/#projects" class="nav-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5"></path><path d="M12 19l-7-7 7-7"></path></svg>
        Back to Home
    </a>
</nav>

<main class="project-deep-dive">
    <section class="section">
        <div class="project-header" style="text-align: center; margin-bottom: 3rem;">
            <div class="project-tech" style="justify-content: center; margin-bottom: 1rem;">{{ tech }}</div>
            <h1 class="hero-name" style="font-size: clamp(3rem, 5vw, 5rem); margin: 0;">{{ title }}<span class="accent-dot">.</span></h1>
            <p style="color: var(--text-secondary); max-width: 600px; margin: 1.5rem auto 0; font-size: 1.25rem;">{{ desc }}</p>
        </div>

        {% if image %}
        <div class="project-hero-image" style="width: 100%; max-width: 1000px; margin: 0 auto 4rem;">
            <img src="{{ image }}" alt="{{ title }}" style="width: 100%; height: auto; border: 1px solid var(--border-color); filter: grayscale(100%);">
        </div>
        {% endif %}

        <div class="project-content" style="max-width: 800px; margin: 0 auto; color: var(--text-secondary); line-height: 1.8; font-size: 1.1rem;">
            {{ content | safe }}
        </div>
    </section>
</main>
