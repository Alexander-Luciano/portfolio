---
layout: base.njk
---
<nav class="main-nav" style="position: relative; margin-top: 2rem; border-bottom: none; background: transparent; backdrop-filter: none;">
    <a href="{{ '/#projects' | url }}" class="nav-item" style="border: none; justify-content: flex-start; padding-left: 0;">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5"></path><path d="M12 19l-7-7 7-7"></path></svg>
        Back to Home
    </a>
</nav>

<main class="project-deep-dive">
    <section class="section" style="border-bottom: none; padding-top: 2rem;">
        <div class="project-header-wrap">
            <div class="project-tech-wrap">
                <span class="tech-pill">{{ tech }}</span>
            </div>
            <h1 class="hero-name" style="font-size: clamp(2.5rem, 5vw, 4.5rem); margin: 0; line-height: 1.1;">{{ title }}<span class="accent-dot">.</span></h1>
            <p style="color: var(--text-secondary); max-width: 600px; margin: 1.5rem auto 0; font-size: 1.25rem; line-height: 1.6;">{{ desc }}</p>
        </div>

        {% if image %}
        <div class="project-hero-image-wrap">
            <img src="{{ image }}" alt="{{ title }}">
        </div>
        {% endif %}

        <div class="project-content">
            {{ content | safe }}
        </div>
    </section>
</main>
